{
  "name": "pvm-php",
  "version": "0.1.1",
  "description": "PHP Version Manager — Simple, fast PHP version management",
  "type": "module",
  "bin": {
    "pvm": "./bin/pvm.js"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nvndevio/pvm.git"
  },
  "homepage": "https://github.com/nvndevio/pvm#readme",
  "bugs": {
    "url": "https://github.com/nvndevio/pvm/issues"
  },
  "scripts": {
    "start": "node bin/pvm.js",
    "postinstall": "node bin/pvm.js env > /dev/null 2>&1 || true"
  },
  "keywords": [
    "php",
    "version-manager",
    "pvm",
    "phpenv",
    "cli",
    "developer-tools",
    "php-version",
    "nvm"
  ],
  "author": "nvndevio",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "ora": "^8.2.0"
  }
}
